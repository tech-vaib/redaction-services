{
  "title": "PII Redaction Service",
  "uid": "pii-redaction-v2",
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(redaction_requests_total[1m]))",
        "legendFormat": "req/s"
      }]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(redaction_errors_total[5m])) / sum(rate(redaction_requests_total[5m]))",
        "legendFormat": "error rate"
      }],
      "options": { "thresholds": { "steps": [
        { "color": "green", "value": 0 },
        { "color": "yellow", "value": 0.001 },
        { "color": "red", "value": 0.01 }
      ]}}
    },
    {
      "id": 3,
      "title": "p99 Latency (ms)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(redaction_request_duration_seconds_bucket[5m])) by (le)) * 1000",
        "legendFormat": "p99 ms"
      }],
      "options": { "thresholds": { "steps": [
        { "color": "green", "value": 0 },
        { "color": "yellow", "value": 200 },
        { "color": "red", "value": 500 }
      ]}}
    },
    {
      "id": 4,
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "redaction_cache_entries",
        "legendFormat": "cache size"
      }]
    },
    {
      "id": 5,
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(redaction_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(redaction_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(redaction_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 6,
      "title": "Requests by Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (endpoint) (rate(redaction_requests_total[1m]))",
        "legendFormat": "{{endpoint}}"
      }]
    },
    {
      "id": 7,
      "title": "Entities Detected by Category",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (category) (rate(redaction_entities_detected_total[5m]))",
        "legendFormat": "{{category}}"
      }]
    },
    {
      "id": 8,
      "title": "Top Entity Types",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "topk(10, sum by (entity_type) (increase(redaction_entities_detected_total[1h])))",
        "legendFormat": "{{entity_type}}"
      }]
    },
    {
      "id": 9,
      "title": "Pipeline Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
      "targets": [{
        "expr": "redaction_queue_depth",
        "legendFormat": "queue depth"
      }]
    },
    {
      "id": 10,
      "title": "Active Workers",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
      "targets": [{
        "expr": "redaction_active_workers",
        "legendFormat": "active workers"
      }]
    },
    {
      "id": 11,
      "title": "Batch Size Distribution",
      "type": "heatmap",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 },
      "targets": [{
        "expr": "sum(rate(redaction_batch_size_bucket[5m])) by (le)",
        "legendFormat": "{{le}}"
      }]
    }
  ]
}
